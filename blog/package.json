{
  "name": "nodejs",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.js",
  "scripts": {
    "beautify": "lint-staged",
    "start": "nodemon --inspect src/index.js",
    "start:prod": "node src/index.js",
    "build:css": "node-sass src/resources/scss/ --output src/public/css/ --output-style compressed",
    "build": "npm run build:css",
    "watch": "node-sass --watch src/resources/scss/ --output src/public/css/",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "src/**/*.{js,json,scss}": [
      "prettier --single-quote --trailing-comma all --tab-width 4 --write"
    ]
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-handlebars": "^8.0.6",
    "mongoose": "^6.13.9",
    "mongoose-slug-generator": "^1.0.4",
    "morgan": "^1.10.1",
    "node-sass": "^9.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1"
  }
}
